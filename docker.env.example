# ---------------------------------------------------------
# DOCKER SECRETS TEMPLATE (docker.env.example)
# ---------------------------------------------------------
# This file IS committed to Git. It acts as a template so 
# other developers know what variables they need to set locally.
# DO NOT PUT REAL PASSWORDS HERE.

# Postgres Container Secrets
POSTGRES_PASSWORD=YOUR_LOCAL_DB_PASSWORD

# API Container Secrets
JwtSettings__Secret=YOUR_LOCAL_JWT_SECRET
AdminSettings__DefaultAdmins__0__Email=YOUR_ADMIN_EMAIL
AdminSettings__DefaultAdmins__0__Password=YOUR_ADMIN_PASSWORD
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=TraderForgeDb;Username=postgres;Password=YOUR_LOCAL_DB_PASSWORD
