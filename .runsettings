<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[*]TraderForge.*.Migrations.*,[*]TraderForge.*.DTOs.*,[*]TraderForge.*.Requests.*,[*]TraderForge.*.Responses.*,[*]TraderForge.API.Program,[TraderForge.Infrastructure]TraderForge.Infrastructure.DependencyInjection</Exclude>
          <ExcludeByAttribute>ExcludeFromCodeCoverage,Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
